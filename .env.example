# Šablona proměnných prostředí pro producthub.
# Zkopíruj tento soubor do `.env` a doplň skutečné hodnoty.
# `.env` je v .gitignore — NIKDY ho necommituj (obsahuje tajemství).
#
# Tip na generování tajemství (spusť v terminálu):
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"   # JWT_SECRET

# === Databáze (PostgreSQL přes Docker) ===
# Uživatel, heslo a databáze odpovídají docker-compose.yml.
# Port 5433 na hostiteli (5432 by kolidoval s Postgresem aplikace vratky).
# Prisma CLI i docker-compose čtou tento `.env` automaticky.
# 127.0.0.1 (ne "localhost") — Windows zkouší u localhost nejdřív IPv6 (::1),
# kde Postgres neposlouchá; explicitní IPv4 adresa ušetří pomalý první pokus.
DATABASE_URL="postgresql://producthub_app:ZMEN_ME@127.0.0.1:5433/producthub?schema=public"
# Heslo pro PostgreSQL v Dockeru — čte ho docker-compose.yml i DATABASE_URL výše (musí se shodovat).
POSTGRES_PASSWORD="ZMEN_ME"

# === Bezpečnost ===
# JWT_SECRET: min. 32 znaků. Podepisuje session tokeny a view tokeny (lib/jwt.ts).
JWT_SECRET="vygeneruj-nahodny-retezec-min-32-znaku"

# === Aplikace ===
APP_URL="http://localhost:3000"

# === Google OAuth (přihlášení) ===
# Založíš v Google Cloud Console → APIs & Services → Credentials → OAuth client ID.
# Redirect URI: http://localhost:3000/api/auth/google/callback (lokálně)
# Návod dostaneš v milníku M2 — do té doby můžou zůstat prázdné.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# === Administrátoři ===
# E-maily oddělené čárkou. Kdo se přihlásí s tímto e-mailem, dostane automaticky
# práva admina (isAdmin) a zakládání projektů (canCreateProjects).
ADMIN_EMAILS="hana.ortmannova@gmail.com"

# === AI (M8 — generování promptu se změnami z komentářů) ===
# API klíč z console.anthropic.com (Settings → API Keys). Bez něj funkce
# „Vytvořit prompt" vrací srozumitelnou hlášku, aplikace nespadne.
# Na produkci se nastavuje jako Railway proměnná (ne do gitu).
ANTHROPIC_API_KEY=""
