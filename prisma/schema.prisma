// Prisma schema pro ProductHub.
// Zdroj pravdy pro strukturu databáze — Prisma z něj generuje TypeScript typy i SQL migrace.
//
// Návrh vychází z design dokumentu docs/design-2026-07-10-producthub.md.
// Před první migrací prošlo schéma review subagentem db-security-expert
// (2026-07-10, verdikt: schváleno s výhradami). Zapracované nálezy jsou
// označené komentářem „po expert review"; závazné podmínky pro další
// milníky (M2 auth, M5 SSRF, M6 limity) jsou v design docu, sekce
// „Závazné podmínky ze security review".
// První migrace navíc obsahuje ruční CHECK constrainty na velikost
// Asset.data a Comment.screenshot (obrana do hloubky pod aplikačními limity).
//
// Zásady onDelete:
//  - Restrict = chraň historii (autoři obsahu, nahrané verze) — smazání uživatele
//    s obsahem není v v1 podporované
//  - Cascade  = data patří rodiči (smazání projektu smaže vše pod ním)
//  - SetNull  = odkaz je jen informativní (schvalovatel, aktér notifikace)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === Enumy ===

// Role člena v projektu. AUTHOR spravuje projekt a schvaluje požadavky,
// COMMENTER komentuje a diskutuje, READER jen čte.
enum ProjectRole {
  AUTHOR
  COMMENTER
  READER
}

// Odkud přišla verze dokumentu: nahraný soubor/ZIP, nebo stažení z URL.
enum DocumentSource {
  UPLOAD
  URL
}

// Viditelnost komentáře. INTERNAL vidí jen interní členové (klient NE).
enum CommentVisibility {
  PUBLIC
  INTERNAL
}

// Stav komentářového vlákna (jen na kořenovém komentáři).
enum CommentStatus {
  OPEN
  RESOLVED
  REOPENED
}

// Workflow požadavku: návrh → schváleno → vygenerován prompt → zapracováno → uzavřeno.
enum RequirementStatus {
  DRAFT
  APPROVED
  PROMPT_GENERATED
  IMPLEMENTED
  CLOSED
}

// Typ notifikace (zvoneček v aplikaci).
enum NotificationType {
  NEW_COMMENT
  NEW_REPLY
  MENTION
  COMMENT_STATUS_CHANGED
  REQUIREMENT_APPROVED
  REQUIREMENT_CLOSED
  PROJECT_INVITED
}

// Stav „zadání" (M8-light): vytvořeno → předáno vývoji → zapracováno.
enum PromptExportStatus {
  CREATED
  HANDED_OFF
  DONE
}

// === Modely ===

// Uživatel — účet vzniká při prvním přihlášení přes Google. Žádná hesla.
model User {
  id                Int      @id @default(autoincrement())
  // Stabilní identifikátor z Google (claim `sub` v id_tokenu) — e-mail se může změnit.
  googleId          String   @unique
  email             String   @unique // vždy lowercase (normalizuje aplikace při zápisu)
  name              String
  avatarUrl         String?
  // Zakládání projektů jen pro označené uživatele (nastavuje admin v /admin/users).
  canCreateProjects Boolean  @default(false)
  isAdmin           Boolean  @default(false)
  // Zneplatnění session: tokeny vydané před tímto časem neplatí (vzor vratky).
  tokenValidFrom    DateTime @default(now())
  // Deaktivace účtu (M4.5, po expert review): vyplněné datum = účet vypnutý.
  // Při deaktivaci se zároveň bumpne tokenValidFrom — zabíjí session (i na
  // proxy vrstvě) a view tokeny okamžitě. Reaktivace tokenValidFrom NEvrací
  // (staré session nesmí obživnout). Data (komentáře, členství, historie)
  // zůstávají — deaktivace NENÍ mazání.
  deactivatedAt     DateTime?
  createdAt         DateTime @default(now())

  createdProjects      Project[]         @relation("ProjectCreator")
  createdClients       Client[]          @relation("ClientCreator")
  memberships          ProjectMember[]
  sentInvitations      Invitation[]      @relation("InvitationSender")
  uploadedVersions     DocumentVersion[] @relation("VersionUploader")
  comments             Comment[]         @relation("CommentAuthor")
  resolvedComments     Comment[]         @relation("CommentResolver")
  mentions             Mention[]
  reactions            Reaction[]
  createdRequirements  Requirement[]     @relation("RequirementCreator")
  approvedRequirements Requirement[]     @relation("RequirementApprover")
  notifications        Notification[]    @relation("NotificationRecipient")
  actedNotifications   Notification[]    @relation("NotificationActor")
  promptExports        PromptExport[]    @relation("PromptExportCreator")
  aiUsage              AiUsage[]
}

// Klient — složka seskupující projekty (DDS, Foto Škoda, Harfasport, … i PB).
// Kopíruje strukturu práce PB (projects/{klient}/). Jen štítek/složka —
// přístupová práva se řídí členstvím v projektech, ne klientem.
model Client {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  createdById Int
  createdBy   User     @relation("ClientCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects Project[]

  @@index([createdById])
}

// Projekt — hlavní objekt systému. Obsahuje dokumenty (HTML specifikace) a členy.
model Project {
  id          Int      @id @default(autoincrement())
  name        String
  description String?  @db.Text
  // Volitelné zařazení pod klienta. Restrict: klient s projekty nejde smazat
  // (nejdřív projekty přesunout/smazat) — projekty nesmí zmizet s klientem.
  clientId    Int?
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: Restrict)
  // Omezení projektu (např. „neměnit design systém") — vkládá se do každého Claude promptu.
  constraints String?  @db.Text
  createdById Int
  createdBy   User     @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members       ProjectMember[]
  invitations   Invitation[]
  documents     Document[]
  comments      Comment[]
  requirements  Requirement[]
  notifications Notification[]
  aiUsage       AiUsage[]

  @@index([createdById])
  @@index([clientId]) // FK index (zásada z expert review)
}

// Členství uživatele v projektu s rolí.
model ProjectMember {
  id         Int         @id @default(autoincrement())
  projectId  Int
  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId     Int
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       ProjectRole
  // Interní člen vidí INTERNAL komentáře (tým PB). Klient má false.
  // Člen s rolí AUTHOR se považuje za interního vždy — vynucuje aplikace.
  isInternal Boolean     @default(false)
  createdAt  DateTime    @default(now())

  @@unique([projectId, userId])
  @@index([userId])
}

// Pozvánka do projektu. Čeká, dokud se pozvaný poprvé nepřihlásí Googlem —
// pak se převede na ProjectMember (párování přes lowercase e-mail).
model Invitation {
  id          Int         @id @default(autoincrement())
  projectId   Int
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  email       String // vždy lowercase
  role        ProjectRole
  isInternal  Boolean     @default(false)
  invitedById Int
  invitedBy   User        @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: Restrict)
  createdAt   DateTime    @default(now())
  acceptedAt  DateTime?

  @@unique([projectId, email])
  @@index([email]) // vyhledání čekajících pozvánek při prvním přihlášení
  @@index([invitedById]) // po expert review: FK index
}

// Dokument — jedna „specifikace" v projektu. Je to celý balík stránek
// (rozcestník + podstránky + assety), ne jediné HTML. Obsah nesou verze.
model Document {
  id        Int      @id @default(autoincrement())
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  versions      DocumentVersion[]
  comments      Comment[]
  requirements  Requirement[]
  promptExports PromptExport[]

  @@index([projectId])
}

// Verze dokumentu — neměnný snapshot všech souborů v okamžiku nahrání/importu.
// Aktuální verze = nejvyšší versionNumber. Staré verze se nemažou (historie).
model DocumentVersion {
  id            Int            @id @default(autoincrement())
  documentId    Int
  document      Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  versionNumber Int
  // Vstupní stránka balíku (např. "index.html") — na ni se otevře prohlížeč.
  entryPath     String         @default("index.html")
  source        DocumentSource
  sourceUrl     String? // jen u source=URL
  uploadedById  Int
  uploadedBy    User           @relation("VersionUploader", fields: [uploadedById], references: [id], onDelete: Restrict)
  createdAt     DateTime       @default(now())

  assets        Asset[]
  comments      Comment[]
  promptExports PromptExport[]

  @@unique([documentId, versionNumber])
  @@index([uploadedById]) // po expert review: FK index
}

// Soubor uvnitř verze dokumentu (HTML stránky, CSS, JS, obrázky, fonty).
// Ukládá se přímo v PostgreSQL (bytea) — žádné externí úložiště.
model Asset {
  id                Int             @id @default(autoincrement())
  documentVersionId Int
  documentVersion   DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  // Relativní cesta v balíku (sanitizovaná — bez „..", bez absolutních cest).
  path              String
  contentType       String
  size              Int
  data              Bytes

  @@unique([documentVersionId, path])
}

// Komentář — kořen vlákna (parentId = null) nese kotvu na element a stav;
// odpovědi nesou jen text. Kotva: preferovaně data-review-id, fallback DOM cesta.
model Comment {
  id                Int             @id @default(autoincrement())
  // Denormalizace projectId: rychlé přístupové kontroly a SSE kanál per projekt.
  projectId         Int
  project           Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documentId        Int
  document          Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  // Verze, ve které komentář vznikl (historie). Po expert review: NoAction
  // místo Cascade/Restrict — PostgreSQL vyhodnocuje NO ACTION až na konci
  // příkazu, takže smazání celého dokumentu projde (komentáře už smazala
  // kaskáda přes documentId), ale smazání JEDNOTLIVÉ verze s komentáři selže
  // chybou. Komentáře tak nejde ztratit omylem (např. ručně v Prisma Studiu).
  documentVersionId Int
  documentVersion   DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: NoAction)
  // Která HTML stránka uvnitř verze (relativní cesta, např. "wf.html").
  pagePath          String
  authorId          Int
  author            User            @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  // Vlákno: odpovědi odkazují na kořenový komentář. Mazání kořene smaže odpovědi.
  parentId          Int?
  parent            Comment?        @relation("Thread", fields: [parentId], references: [id], onDelete: Cascade)
  replies           Comment[]       @relation("Thread")

  body       String            @db.Text
  visibility CommentVisibility @default(PUBLIC)
  status     CommentStatus     @default(OPEN)

  // Kotva na element (jen kořen vlákna):
  dataReviewId   String?
  domPath        String? @db.Text
  // HTML výstřižek elementu v okamžiku komentáře — kontext pro diskusi i Claude prompt.
  elementHtml    String? @db.Text
  // Screenshot v v1 nevyužitý (rozhodnutí z brainstormingu) — sloupec připraven pro v2.
  screenshot     Bytes?
  viewportWidth  Int?
  viewportHeight Int?
  // Element v nové verzi dokumentu nenalezen (po migraci kotev).
  isOrphaned     Boolean @default(false)

  resolvedById Int?
  resolvedBy   User?     @relation("CommentResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolvedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mentions         Mention[]
  reactions        Reaction[]
  requirementLinks RequirementComment[]
  notifications    Notification[]

  @@index([documentId, pagePath, status])
  @@index([projectId, createdAt])
  @@index([parentId])
  @@index([documentVersionId])
  @@index([authorId])
  @@index([resolvedById]) // po expert review: FK index
}

// Zmínka @uživatel v komentáři — pro notifikace a našeptávač.
model Mention {
  id        Int     @id @default(autoincrement())
  commentId Int
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId])
}

// Reakce emoji na komentář — lehká zpětná vazba bez psaní (👍 ✅ 👀 …).
// Po expert review: emoji má DB délkový strop (obrana do hloubky nad Zod enum);
// samostatný commentId index je redundantní (unique má commentId vedoucí).
model Reaction {
  id        Int     @id @default(autoincrement())
  commentId Int
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Omezená sada emoji — validaci hlídá kód (Zod enum), NE libovolný string.
  // VarChar(16) = obrana do hloubky proti zápisu mimo aplikační cestu.
  emoji     String  @db.VarChar(16)
  createdAt DateTime @default(now())

  // Jeden uživatel = jedna reakce daného emoji na komentář (toggle přes create/delete).
  @@unique([commentId, userId, emoji])
  @@index([userId])
}

// Požadavek — strukturovaný výstup diskuse, podklad pro Claude Code prompt.
model Requirement {
  id          Int       @id @default(autoincrement())
  projectId   Int
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // Hlavní dotčený dokument (informativní — může zaniknout nezávisle na požadavku).
  documentId  Int?
  document    Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  createdById Int
  createdBy   User      @relation("RequirementCreator", fields: [createdById], references: [id], onDelete: Restrict)

  title              String
  description        String            @db.Text
  acceptanceCriteria String            @db.Text
  // Textový popis dotčeného elementu (data-review-id / DOM cesta).
  affectedElement    String?
  status             RequirementStatus @default(DRAFT)

  generatedPrompt   String?   @db.Text
  promptGeneratedAt DateTime?
  // Po expert review: Restrict místo SetNull — schválení je bezpečnostně
  // významná akce, audit „kdo schválil" se nesmí ztratit.
  approvedById      Int?
  approvedBy        User?     @relation("RequirementApprover", fields: [approvedById], references: [id], onDelete: Restrict)
  approvedAt        DateTime?
  closedAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  commentLinks  RequirementComment[]
  notifications Notification[]

  @@index([projectId, status])
  // Po expert review: FK indexy
  @@index([documentId])
  @@index([createdById])
  @@index([approvedById])
}

// Vazba požadavek ↔ komentáře, ze kterých vznikl (diskuse jde do promptu).
model RequirementComment {
  id            Int         @id @default(autoincrement())
  requirementId Int
  requirement   Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  commentId     Int
  comment       Comment     @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([requirementId, commentId])
  @@index([commentId])
}

// Notifikace v aplikaci (zvoneček). Doručuje se i živě přes SSE.
model Notification {
  id            Int              @id @default(autoincrement())
  userId        Int // příjemce
  user          User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  type          NotificationType
  projectId     Int
  project       Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  commentId     Int?
  comment       Comment?         @relation(fields: [commentId], references: [id], onDelete: Cascade)
  requirementId Int?
  requirement   Requirement?     @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  // Kdo akci vyvolal (informativní — při smazání uživatele se jen odpojí).
  actorId       Int?
  actor         User?            @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  readAt    DateTime?

  @@index([userId, readAt])
  @@index([userId, createdAt])
  // Po expert review: indexy na FK — Notification je největší rostoucí tabulka
  // a kaskádová mazání komentářů/vláken by bez nich dělala seq scan.
  @@index([projectId])
  @@index([commentId])
  @@index([requirementId])
}

// „Zadání" (M8-light) — snapshot promptu vygenerovaného z vybraných komentářů,
// určený k předání vývoji (Claude Code). Uložený text = auditní stopa „co šlo
// vývoji". Po db-security-expert review (2026-07-17, schváleno s výhradami):
//  - denormalizovaný documentId (Cascade) + documentVersionId NoAction (vzor
//    Comment): chrání historii, ale nezablokuje smazání dokumentu;
//  - body MŮŽE obsahovat text INTERNAL komentářů → čtení/výpis jen internímu
//    členovi projektu (vynucuje aplikace; server nikdy nevrací body neinternímu);
//  - CHECK constrainty na velikost body a počet commentIds jsou v migraci.
model PromptExport {
  id                Int             @id @default(autoincrement())
  documentId        Int
  document          Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentVersionId Int
  documentVersion   DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: NoAction)
  createdById       Int
  createdBy         User            @relation("PromptExportCreator", fields: [createdById], references: [id], onDelete: Restrict)

  title  String @db.VarChar(200)
  // Snapshot promptu — NIKDY nevracet neinternímu členovi (může nést INTERNAL text).
  body   String @db.Text
  // Informativní seznam zahrnutých komentářů; zdroj pravdy je body. NEpoužívat
  // k opětovnému načtení komentářů (obešlo by filtr viditelnosti).
  commentIds Int[] @default([])
  status     PromptExportStatus @default(CREATED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([documentId])
  @@index([documentVersionId])
  @@index([createdById])
}

// App-wide konfigurace (jediný řádek, id=1). Drží šifrovaný Anthropic API klíč
// a měsíční limit generování. Po db-security-expert review (2026-07-20):
//  - klíč AES-256-GCM ciphertext ("v1:iv:tag:ct" base64), šifr. klíč ze
//    samostatné env SECRET_ENC_KEY (ne z JWT_SECRET — ten se rotuje);
//  - klíč se NIKDY nevrací klientovi (GET vrací jen keyLast4), dešifruje se
//    JEN server-side při volání Claude;
//  - single-row vynucen CHECK (id=1) v migraci; přístup jen isAdmin.
model AppConfig {
  id                   Int      @id @default(1)
  anthropicApiKeyEnc   String?  @db.Text
  anthropicApiKeyLast4 String?  @db.VarChar(8)
  // Měsíční rozpočet na AI generování v CENTECH USD (0 = bez limitu). Cents
  // (Int) kvůli přesnosti; aplikace 0 vyhodnocuje zvlášť jako „bez limitu".
  monthlyBudgetUsdCents Int     @default(0)
  updatedAt            DateTime @updatedAt
}

// Log každého AI generování — podklad pro měsíční limit a přehled nákladů.
// SetNull u projectId/userId: log zůstává pro účetnictví i po smazání
// projektu/uživatele. CHECK na nezáporné tokeny je v migraci (obrana do hloubky).
model AiUsage {
  id           Int      @id @default(autoincrement())
  projectId    Int?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId       Int?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  model        String   @db.VarChar(64)
  inputTokens  Int
  outputTokens Int
  createdAt    DateTime @default(now())

  @@index([createdAt]) // měsíční count
  @@index([projectId]) // FK index
  @@index([userId]) // FK index (po expert review K1)
}
